<?xml version="1.0" ?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Postman Plan" enabled="true"/>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Users" enabled="true"/>
      <hashTree>
        <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Loop" enabled="true"/>
        <hashTree>
          <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="CreateBooking" enabled="true"/>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="CreateToken" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/auth</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="CreateBooking" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/booking</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
          </hashTree>
          <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Create Login token" enabled="true"/>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="CreateToken" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/auth</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
          </hashTree>
          <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Check booking details" enabled="true"/>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GetBookingIds" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/booking?checkin={{checkinDate}}&amp;checkout={{checkoutDate}}</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
          </hashTree>
          <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Check created booking details" enabled="true"/>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="CreateBooking" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/booking</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GetBooking" enabled="true">
              <stringProp name="HTTPSampler.domain">restful-booker.herokuapp.com</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">/booking/{{createdBookingId}}</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <hashTree/>
            </HTTPSamplerProxy>
          </hashTree>
        </hashTree>
      </hashTree>
    </hashTree>
