    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "const firstBookingId = response.bookingid;",
              "",
              "pm.collectionVariables.set(\"createdBookingId\", firstBookingId);",
              "",
              "console.log(\"First Booking ID:\", firstBookingId);",
              "",
              "pm.test(\"Check if booking ID is greater than 0\", function () {",
              "    pm.expect(firstBookingId).to.be.greaterThan(0);",
              "    });",
              "pm.test(\"Check if booking ID is a number\", function () {",
              "    pm.expect(firstBookingId).to.be.a('number');",
              "    });",
              "pm.test(\"Check if booking ID is an integer\", function () {",
              "    pm.expect(firstBookingId).to.be.an('integer');",
              "    });",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Check if booking details are correct\", function () {",
              "    pm.expect(response.booking.firstname).to.eql(\"Jim\");",
              "    pm.expect(response.booking.lastname).to.eql(\"Brown\");",
              "    pm.expect(response.booking.totalprice).to.eql(111);",
              "    pm.expect(response.booking.depositpaid).to.eql(true);",
              "    pm.expect(response.booking.bookingdates.checkin).to.eql(\"2018-01-01\");",
              "    pm.expect(response.booking.bookingdates.checkout).to.eql(\"2019-01-01\");",
              "    pm.expect(response.booking.additionalneeds).to.eql(\"Breakfast\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const currentYear = new Date().getFullYear();",
              "",
              "// Jan 1st of current year",
              "const start = new Date(currentYear, 0, 1);",
              "",
              "// Dec 31st of current year",
              "const end = new Date(currentYear, 11, 31);",
              "",
              "// Random date between start and end",
              "const randomDate = new Date(",
              "    start.getTime() +",
              "    Math.random() * (end.getTime() - start.getTime())",
              ");",
              "",
              "// Format YYYY-MM-DD",
              "const formattedDate =",
              "    randomDate.getFullYear() + \"-\" +",
              "    String(randomDate.getMonth() + 1).padStart(2, \"0\") + \"-\" +",
              "    String(randomDate.getDate()).padStart(2, \"0\");",
              "",
              "// Format YYYY-MM-DD",
              "const formattedDateEnd =",
              "    randomDate.getFullYear() + \"-\" +",
              "    String(randomDate.getMonth() + 1).padStart(2, \"0\") + \"-\" +",
              "    String(randomDate.getDate()).padStart(2, \"0\");",
              "",
              "// Save variable",
              "pm.collectionVariables.set(\"checkinDate\", formattedDate);",
              "pm.collectionVariables.set(\"checkoutDate\", formattedDateEnd);",
              "",
              "console.log(\"Checkin Date:\", formattedDate);",
              "console.log(\"Checkout Date:\", formattedDateEnd);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
